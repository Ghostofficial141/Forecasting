# Exclude Python backend and heavy libraries from Vercel deployment bundle
api/
src/
tests/
venv/
.venv/
env/
requirements.txt
Dockerfile
docker-compose.yml
main.py
setup.py
setup.cfg
scratch/
scratch_inspect.py
package-lock.json

# Exclude Next.js source code if you only want to serve the static dashboard from root
# (If deploying the Next.js app, Vercel should be configured with Root Directory as 'dashboard')
dashboard/node_modules/
dashboard/.next/
